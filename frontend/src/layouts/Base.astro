---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
}
const { title, description = 'BRCPrint – Impressão 3D Profissional', showNav = true } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | BRCPrint</title>
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --accent: #00f2ff;
      --neon-purple: #bc13fe;
      --neon-green: #00ff94;
      --bg: #05060a;
      --border: rgba(255,255,255,0.08);
      --muted: rgba(255,255,255,0.45);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: #fff;
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* ---- NAVBAR ---- */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      height: 64px;
      background: rgba(5,6,10,0.85);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(20px);
      display: flex;
      align-items: center;
      padding: 0 2rem;
      gap: 2rem;
    }
    .navbar-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; flex-shrink: 0; }
    .navbar-logo img { height: 36px; }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      margin-left: 1rem;
    }
    .nav-link {
      padding: 0.5rem 0.875rem;
      color: var(--muted);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      transition: color 0.2s;
      border-radius: 2px;
    }
    .nav-link:hover, .nav-link.active { color: #fff; }
    .nav-link.leilao { color: var(--neon-purple); }
    .nav-link.leilao:hover { color: #d04dff; }
    .navbar-right { margin-left: auto; display: flex; align-items: center; gap: 1rem; }
    .cart-btn {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.5rem 0.875rem;
      color: var(--muted); text-decoration: none;
      font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
      transition: color 0.2s;
    }
    .cart-btn:hover { color: #fff; }
    .btn-login {
      padding: 0.55rem 1.25rem;
      border: 1px solid #fff;
      color: #fff;
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      border-radius: 2px;
      transition: all 0.2s;
      display: none; /* hidden until JS runs */
    }
    .btn-login:hover { background: rgba(255,255,255,0.08); }
    .btn-dashboard {
      padding: 0.55rem 1.25rem;
      border: 1px solid var(--accent);
      color: var(--accent);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
      border-radius: 2px;
      transition: all 0.2s;
      display: none;
    }
    .btn-dashboard:hover { background: rgba(0,242,255,0.1); }
    /* Push content below fixed navbar */
    .navbar + * { padding-top: 64px; }
    main { padding-top: 64px; }
    /* Mobile nav toggle */
    .nav-toggle { display: none; cursor: pointer; background: transparent; border: none; color: var(--muted); font-size: 1.5rem; }
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-links.open { display: flex; flex-direction: column; position: absolute; top: 64px; left: 0; right: 0; background: rgba(5,6,10,0.98); padding: 1.5rem; border-bottom: 1px solid var(--border); gap: 0.5rem; }
      .nav-toggle { display: block; }
    }
  </style>
</head>
<body>
  {showNav && (
    <nav class="navbar">
      <a href="/" class="navbar-logo">
        <img src="/brcprint.svg" alt="BRCPrint Logo" onerror="this.style.display='none'" />
        <span style="font-weight:900;font-size:1rem;letter-spacing:2px;color:#fff;">BRCPRINT</span>
      </a>

      <button class="nav-toggle" id="nav-toggle" aria-label="Menu">☰</button>

      <div class="nav-links" id="nav-links">
        <a href="/catalogo" class={`nav-link ${currentPath.startsWith('/catalogo') ? 'active' : ''}`}>CATÁLOGO</a>
        <a href="/modelos-parametricos" class={`nav-link ${currentPath.startsWith('/modelos-parametricos') ? 'active' : ''}`}>MODELOS</a>
        <a href="/leiloes" class={`nav-link leilao ${currentPath.startsWith('/leilao') ? 'active' : ''}`}>LEILÃO</a>
        <a href="/contato" class={`nav-link ${currentPath.startsWith('/contato') ? 'active' : ''}`}>CONTATO</a>
      </div>

      <div class="navbar-right">
        <a href="/carrinho" class="cart-btn" id="cart-link">
          🛒 <span>CARRINHO</span><span id="cart-badge" style="display:none;background:var(--accent);color:#000;font-size:0.6rem;font-weight:900;border-radius:999px;padding:0.1rem 0.4rem;margin-left:0.35rem;"></span>
        </a>
        <a href="/minha-conta/login" class="btn-login" id="btn-login">LOGIN</a>
        <a href="/minha-conta" class="btn-dashboard" id="btn-dashboard">MINHA CONTA</a>
      </div>
    </nav>
  )}

  <slot />

  <script>
    // Mobile toggle
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      document.getElementById('nav-links')?.classList.toggle('open');
    });
    // Auth state
    const token = localStorage.getItem('brc_token');
    const loginBtn = document.getElementById('btn-login') as HTMLElement;
    const dashBtn = document.getElementById('btn-dashboard') as HTMLElement;
    if (loginBtn && dashBtn) {
      if (token) { dashBtn.style.display = 'block'; loginBtn.style.display = 'none'; }
      else { loginBtn.style.display = 'block'; dashBtn.style.display = 'none'; }
    }
    // Cart badge
    try {
      const cart = JSON.parse(localStorage.getItem('brc_cart') || '[]');
      const count = cart.reduce((a: number, i: any) => a + (i.quantity || 1), 0);
      const badge = document.getElementById('cart-badge') as HTMLElement;
      if (badge && count > 0) { badge.textContent = String(count); badge.style.display = 'inline-block'; }
    } catch {}
    // Listen for cart changes
    window.addEventListener('storage', () => {
      try {
        const cart = JSON.parse(localStorage.getItem('brc_cart') || '[]');
        const count = cart.reduce((a: number, i: any) => a + (i.quantity || 1), 0);
        const badge = document.getElementById('cart-badge') as HTMLElement;
        if (badge) { badge.textContent = String(count); badge.style.display = count > 0 ? 'inline-block' : 'none'; }
      } catch {}
    });
  </script>
</body>
</html>
