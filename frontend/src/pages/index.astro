---
import Base from '../layouts/Base.astro';

// Buscar dados dinâmicos da FastAPI
const API = import.meta.env.API_INTERNAL_URL || 'http://fastapi:8000';

let reviews: any[] = [];
let parametricModels: any[] = [];
let activeAuctions: any[] = [];

try {
  const [rRes, mRes, aRes] = await Promise.allSettled([
    fetch(`${API}/api/v1/catalog/reviews`),
    fetch(`${API}/api/v1/catalog/parametric-models`),
    fetch(`${API}/api/v1/catalog/auctions`),
  ]);
  if (rRes.status === 'fulfilled' && rRes.value.ok) reviews = await rRes.value.json();
  if (mRes.status === 'fulfilled' && mRes.value.ok) parametricModels = await mRes.value.json();
  if (aRes.status === 'fulfilled' && aRes.value.ok) activeAuctions = await aRes.value.json();
} catch (e) {
  // Sem dados dinâmicos — modo demo
}
---

<Base title="BRCPrint — Impressão 3D Profissional sob Demanda">

<!-- ═══════════════════════════════════════════════
  ESTILOS CYBER / FUTURISTA (idênticos ao Next.js)
════════════════════════════════════════════════ -->
<style>
  :root {
    --accent: #00f2ff;
    --neon-purple: #bc13fe;
    --neon-green: #00ff94;
    --background: #05060a;
    --border: rgba(255,255,255,0.08);
    --text: #ffffff;
    --muted: rgba(255,255,255,0.45);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--background);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
  }

  .bg-mesh-dark {
    background: var(--background);
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(0,242,255,0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(188,19,254,0.04) 0%, transparent 50%);
  }

  .glass-panel {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hover-glow { transition: box-shadow 0.3s ease, transform 0.3s ease; }
  .hover-glow:hover {
    box-shadow: 0 0 40px rgba(0,242,255,0.12);
    transform: translateY(-2px);
  }

  .hover-glow-text { transition: color 0.2s ease, text-shadow 0.2s ease; }
  .hover-glow-text:hover {
    color: var(--accent) !important;
    text-shadow: 0 0 20px var(--accent);
  }

  .gradient-text {
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-image: linear-gradient(90deg, var(--accent), var(--neon-purple));
    display: inline-block;
  }

  .cyber-button {
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
    position: relative;
  }
  .cyber-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .cyber-button:hover { background: rgba(0,242,255,0.1); box-shadow: 0 0 30px rgba(0,242,255,0.3); }
  .cyber-button span { position: relative; z-index: 1; }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #4f46e5);
    color: #000;
    font-weight: 800;
    border: none;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(0,242,255,0.4); }

  .btn-ghost {
    color: #fff;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.1) !important; }

  .pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(0,242,255,0.4); }
    50% { box-shadow: 0 0 50px rgba(0,242,255,0.8); }
  }

  @keyframes scanning {
    0% { top: 0; }
    50% { top: calc(100% - 2px); }
    100% { top: 0; }
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up { animation: fade-in-up 0.8s ease forwards; }

  /* Reveal on scroll */
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  .reveal-left { opacity: 0; transform: translateX(-60px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal-left.visible { opacity: 1; transform: none; }

  /* Nav */
  nav.main-nav a { transition: color 0.2s; }

  /* Hero */
  .hero-section {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 0 6rem;
    gap: 6rem;
    position: relative;
  }

  /* Steps */
  .step-card {
    display: flex;
    align-items: center;
    gap: 4rem;
    border: 1px solid var(--border);
    padding: 4rem;
    border-radius: 4px;
    background: rgba(10,12,18,0.6);
    margin-bottom: 4rem;
  }
  .step-card-reverse {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 4rem;
    border: 1px solid var(--border);
    padding: 4rem;
    border-radius: 4px;
    background: rgba(10,12,18,0.6);
    margin-bottom: 4rem;
  }

  /* Benefits grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 900px) {
    .hero-section { flex-direction: column; padding: 4rem 2rem; min-height: auto; }
    .step-card, .step-card-reverse { flex-direction: column; padding: 2rem; }
    header { padding: 1rem !important; }
    nav.main-nav { display: none; }
    h2[style*="6.5rem"] { font-size: 3.5rem !important; }
    h2[style*="5rem"] { font-size: 2.8rem !important; }
    h2[style*="4rem"] { font-size: 2.5rem !important; }
  }
</style>

<div class="bg-mesh-dark" style="flex:1;display:flex;flex-direction:column;min-height:100vh;">

<!-- ─── NAVBAR ───────────────────────────────────────────────── -->
<header style="display:flex;align-items:center;justify-content:space-between;padding:0.8rem 3rem;border-bottom:1px solid var(--border);position:sticky;top:0;background:rgba(5,6,10,0.85);backdrop-filter:blur(15px);z-index:1000;">
  <div style="display:flex;align-items:center;gap:0.8rem;">
    <img src="/brcprint.svg" alt="BRCPrint Logo" style="height:42px;" />
    <div style="width:2px;height:20px;background:var(--accent);"></div>
  </div>

  <nav class="main-nav" style="display:flex;align-items:center;gap:2.5rem;">
    <a href="/catalogo" class="hover-glow-text" style="color:var(--text);text-decoration:none;font-weight:700;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;">CATÁLOGO</a>
    <a href="/modelos-parametricos" class="hover-glow-text" style="color:rgba(255,255,255,0.6);text-decoration:none;font-weight:500;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;">PERSONALIZÁVEIS</a>
    <a href="/leiloes" class="hover-glow-text" style="color:var(--neon-purple);text-decoration:none;font-weight:800;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;">LEILÃO</a>
    <a href="/contato" class="hover-glow-text" style="color:rgba(255,255,255,0.6);text-decoration:none;font-weight:500;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;">CONTATO</a>
    <a href="/carrinho" class="hover-glow-text" style="display:flex;align-items:center;gap:0.5rem;color:var(--text);text-decoration:none;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span style="font-size:0.85rem;font-weight:700;">CARRINHO</span>
    </a>
    <a href="/minha-conta/login" class="cyber-button" style="padding:0.6rem 2rem;font-size:0.8rem;border-radius:4px;">LOGIN</a>
  </nav>
</header>

<!-- ─── HERO ─────────────────────────────────────────────────── -->
<section class="hero-section">
  <!-- Glow blob bg -->
  <div style="position:absolute;top:10%;right:10%;width:50vw;height:50vw;background:radial-gradient(circle,rgba(0,242,255,0.1) 0%,transparent 70%);filter:blur(100px);z-index:0;pointer-events:none;"></div>

  <!-- Texto esquerdo -->
  <div class="reveal-left" style="position:relative;z-index:10;flex:1;">
    <div style="display:inline-flex;align-items:center;gap:1rem;padding:0.5rem 1.5rem;border-radius:4px;background:rgba(0,242,255,0.05);border-left:4px solid var(--accent);color:var(--accent);font-weight:900;font-size:0.75rem;text-transform:uppercase;letter-spacing:4px;margin-bottom:3rem;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Protocolo de Produção Ativo
    </div>

    <h1 style="font-size:clamp(3rem,7vw,6.5rem);line-height:1;font-weight:900;margin-bottom:2rem;letter-spacing:-3px;text-transform:uppercase;font-style:italic;">
      <span style="color:white;">Cyber</span><br/>
      <span class="gradient-text" style="background-image:linear-gradient(90deg,var(--accent),var(--neon-purple));padding-right:0.5rem;">BRCPRINT</span>
    </h1>

    <p style="color:rgba(255,255,255,0.7);font-size:1.2rem;margin-bottom:4rem;max-width:550px;line-height:1.6;border-left:1px solid var(--border);padding-left:1.5rem;">
      Inicie o protocolo de fabricação aditiva em segundos.<br/>
      <span style="color:var(--accent);">Fonte digital. Saída física. Controle total.</span>
    </p>

    <div style="display:flex;gap:2rem;align-items:center;flex-wrap:wrap;">
      <a href="/minha-conta/nova-cotacao" class="cyber-button" style="padding:1.5rem 4rem;font-size:1rem;border-radius:2px;">INICIAR PROJETO</a>
      <a href="#como-funciona" class="hover-glow-text" style="color:var(--text);text-decoration:none;font-size:0.9rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;display:flex;align-items:center;gap:0.8rem;">
        Entenda Mais
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </a>
    </div>

    <!-- Stats -->
    <div style="display:flex;gap:4rem;margin-top:6rem;flex-wrap:wrap;">
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <span style="font-size:2.5rem;font-weight:900;color:var(--accent);line-height:1;">02.5s</span>
        <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:2px;">Ping</span>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <span style="font-size:2.5rem;font-weight:900;color:var(--neon-purple);line-height:1;">GARANTIA</span>
        <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:2px;">Pagamento Seguro</span>
      </div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <span style="font-size:2.5rem;font-weight:900;color:var(--neon-green);line-height:1;">AUTO</span>
        <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:2px;">Automatização</span>
      </div>
    </div>
  </div>

  <!-- Visual direito — HUD card 3D -->
  <div style="flex:1;display:flex;justify-content:center;align-items:center;z-index:5;">
    <div style="position:relative;">
      <!-- Cantos HUD -->
      <div style="position:absolute;top:-40px;left:-40px;border:2px solid var(--accent);width:100px;height:100px;border-right:0;border-bottom:0;z-index:10;"></div>
      <div style="position:absolute;bottom:-40px;right:-40px;border:2px solid var(--neon-purple);width:100px;height:100px;border-left:0;border-top:0;z-index:10;"></div>
      <!-- Texto lateral vertical -->
      <div style="position:absolute;top:50%;right:-60px;transform:translateY(-50%);writing-mode:vertical-rl;font-size:0.6rem;color:var(--accent);letter-spacing:4px;font-weight:900;text-transform:uppercase;">Varredura do buffer ativo</div>

      <!-- Área 3D / Placeholder visual -->
      <div style="width:clamp(300px,40vw,550px);height:clamp(300px,40vw,550px);background:rgba(0,0,0,0.4);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
        <!-- Linha de scan animada -->
        <div style="position:absolute;top:0;left:0;width:100%;height:2px;background:var(--accent);box-shadow:0 0 20px var(--accent);animation:scanning 4s ease-in-out infinite;"></div>

        <!-- Ícone central -->
        <div style="display:flex;flex-direction:column;align-items:center;gap:1rem;opacity:0.6;">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="0.5">
            <rect x="2" y="2" width="20" height="20" rx="2"/>
            <path d="M12 2v20M2 12h20"/>
            <circle cx="12" cy="12" r="4"/>
          </svg>
          <span style="font-size:0.7rem;color:var(--accent);letter-spacing:4px;font-weight:900;">STL/3MF/OBJ</span>
        </div>

        <!-- Barras de métricas no rodapé -->
        <div style="position:absolute;bottom:20px;left:20px;right:20px;display:flex;gap:2px;align-items:flex-end;height:40px;">
          {[40,70,30,90,50,80,40,60,85,45].map((h) => (
            <div style={`flex:1;height:${h}%;background:var(--accent);opacity:0.5;`}></div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── FLUXO DO SISTEMA (3 passos) ────────────────────────── -->
<section id="como-funciona" style="padding:10rem 4rem;position:relative;z-index:10;">
  <div style="max-width:1200px;margin:0 auto;">
    <div class="reveal" style="display:flex;align-items:flex-end;gap:2rem;margin-bottom:6rem;">
      <h2 style="font-size:clamp(2.5rem,5vw,5rem);font-weight:900;line-height:1;text-transform:uppercase;letter-spacing:-3px;">
        FLUXO DO<br/><span style="color:var(--accent);">SISTEMA</span>
      </h2>
      <div style="flex:1;height:2px;background:linear-gradient(90deg,var(--accent),transparent);margin-bottom:1rem;"></div>
    </div>

    <!-- Passo 1 -->
    <div class="step-card hover-glow reveal">
      <div style="flex:1;">
        <div style="font-size:0.8rem;font-weight:900;color:var(--accent);letter-spacing:4px;text-transform:uppercase;margin-bottom:1rem;">Passo 1</div>
        <h3 style="font-size:2.5rem;margin-bottom:1.5rem;font-weight:900;text-transform:uppercase;">UPLOAD DOS ARQUIVOS</h3>
        <p style="color:rgba(255,255,255,0.6);font-size:1.1rem;line-height:1.8;margin-bottom:2rem;">
          Nossos algoritmos realizam uma varredura completa na geometria do seu arquivo 3D em milissegundos.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div style="padding:1rem;border:1px solid var(--border);font-size:0.75rem;color:var(--accent);">[ STL / OBJ / 3MF ]</div>
          <div style="padding:1rem;border:1px solid var(--border);font-size:0.75rem;color:var(--neon-green);">FATIAMENTO EM TEMPO REAL</div>
        </div>
      </div>
      <div style="flex:1;display:flex;justify-content:center;">
        <div style="width:100%;height:350px;border:1px solid var(--border);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);">
          <div style="position:absolute;top:0;left:0;width:100%;height:2px;background:var(--accent);box-shadow:0 0 20px var(--accent);animation:scanning 4s ease-in-out infinite;"></div>
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="0.5" style="opacity:0.3;"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 3v18M3 12h18"/></svg>
          <span style="font-size:4rem;position:absolute;">📁</span>
        </div>
      </div>
    </div>

    <!-- Passo 2 -->
    <div class="step-card-reverse hover-glow reveal">
      <div style="flex:1;">
        <div style="font-size:0.8rem;font-weight:900;color:var(--neon-purple);letter-spacing:4px;text-transform:uppercase;margin-bottom:1rem;">Passo 2</div>
        <h3 style="font-size:2.5rem;margin-bottom:1.5rem;font-weight:900;text-transform:uppercase;">PAGAMENTO POR PIX</h3>
        <p style="color:rgba(255,255,255,0.6);font-size:1.1rem;line-height:1.8;margin-bottom:2rem;">
          Transação via Pix com reconhecimento de rede instantâneo. Sem espera, sem erros de processamento.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div style="padding:1rem;border:1px solid var(--border);font-size:0.75rem;color:var(--neon-purple);">VALIDAÇÃO INSTANTÂNEA</div>
          <div style="padding:1rem;border:1px solid var(--border);font-size:0.75rem;color:var(--neon-green);">MERCADO PAGO</div>
        </div>
      </div>
      <div style="flex:1;display:flex;justify-content:center;">
        <div style="width:100%;height:350px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);position:relative;">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="var(--neon-purple)" stroke-width="0.5" style="opacity:0.3;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span style="color:var(--neon-purple);font-size:5rem;font-weight:900;">QR</span>
        </div>
      </div>
    </div>

    <!-- Passo 3 -->
    <div class="step-card hover-glow reveal">
      <div style="flex:1;">
        <div style="font-size:0.8rem;font-weight:900;color:var(--neon-green);letter-spacing:4px;text-transform:uppercase;margin-bottom:1rem;">Passo 3</div>
        <h3 style="font-size:2.5rem;margin-bottom:1.5rem;font-weight:900;text-transform:uppercase;">DIRETO PARA A MÁQUINA</h3>
        <p style="color:rgba(255,255,255,0.6);font-size:1.1rem;line-height:1.8;margin-bottom:2rem;">
          Sem baixar e passar arquivo para pen-drive ou SD. O sistema conecta na sua rede via IoT e aciona a máquina correta para começar a produção.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;">
          {["Controle de Fila Inteligente", "Métricas em Tempo Real"].map((item) => (
            <div style="padding:1rem;border:1px solid var(--border);font-size:0.75rem;color:var(--neon-green);flex:1 1 calc(50% - 0.5rem);">✓ {item.toUpperCase()}</div>
          ))}
        </div>
      </div>
      <div style="flex:1;display:flex;justify-content:center;">
        <div style="width:100%;height:350px;border:1px solid var(--border);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);">
          <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="var(--neon-green)" stroke-width="0.5" style="opacity:0.3;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span style="font-size:1.5rem;font-weight:900;color:var(--neon-green);letter-spacing:2px;position:absolute;bottom:10%;right:10%;opacity:0.5;">IoT ATIVADO</span>
          <div style="display:flex;gap:2px;align-items:flex-end;height:40px;position:absolute;bottom:20px;left:20px;">
            {[40,70,30,90,50,80,40].map((h) => (
              <div style={`width:4px;height:${h}%;background:var(--neon-green);opacity:0.6;`}></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── B2B / PRODUÇÃO INTELIGENTE ──────────────────────────── -->
<section id="b2b-manufatura" style="padding:10rem 4rem;position:relative;border-top:1px solid var(--border);background:rgba(0,242,255,0.02);">
  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;">
    <div class="reveal-left">
      <div style="font-size:0.8rem;font-weight:900;color:var(--neon-green);letter-spacing:4px;text-transform:uppercase;margin-bottom:2rem;">Acesso Nível Industrial</div>
      <h2 style="font-size:clamp(2rem,4vw,4rem);font-weight:900;margin-bottom:2rem;text-transform:uppercase;line-height:1;">
        PRODUÇÃO<br/><span style="color:var(--neon-green);">INTELIGENTE</span>
      </h2>
      <p style="color:rgba(255,255,255,0.6);font-size:1.2rem;line-height:1.8;margin-bottom:3rem;">
        Conecte sua empresa ao cluster de manufatura digital mais avançado do país. Peças técnicas, brindes e produção sob demanda.
      </p>
      <div style="display:flex;flex-direction:column;gap:1.5rem;margin-bottom:4rem;">
        {["Engenharia Avançada", "Materiais Técnicos", "Escalabilidade Imediata"].map((item) => (
          <div style="display:flex;align-items:center;gap:1.5rem;">
            <div style="width:10px;height:10px;background:var(--neon-green);border-radius:2px;flex-shrink:0;"></div>
            <span style="font-size:1rem;font-weight:800;text-transform:uppercase;letter-spacing:1px;">{item}</span>
          </div>
        ))}
      </div>
