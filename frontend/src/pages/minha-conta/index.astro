---
import Base from '../../layouts/Base.astro';

// SSR: verificar auth via cookie/header
const token = Astro.cookies.get('brc_token')?.value;
let client = null;
let quotes: any[] = [];

if (token) {
  const API = import.meta.env.API_INTERNAL_URL || 'http://fastapi:8000';
  try {
    const [clientRes, quotesRes] = await Promise.allSettled([
      fetch(`${API}/api/v1/clients/me`, { headers: { Authorization: `Bearer ${token}` } }),
      fetch(`${API}/api/v1/quotes/my`, { headers: { Authorization: `Bearer ${token}` } }),
    ]);
    if (clientRes.status === 'fulfilled' && clientRes.value.ok) client = await clientRes.value.json();
    if (quotesRes.status === 'fulfilled' && quotesRes.value.ok) quotes = await quotesRes.value.json();
  } catch {}
}
---

<Base title="Minha Conta — BRCPrint">
<style>
  :root { --accent: #00f2ff; --neon-green: #00ff94; --border: rgba(255,255,255,0.08); --muted: rgba(255,255,255,0.45); }
  body { background: #05060a; color: #fff; font-family: 'Inter', sans-serif; }
  .layout { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
  .sidebar { background: rgba(10,12,18,0.95); border-right: 1px solid var(--border); padding: 2rem 1.5rem; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
  .main { padding: 2.5rem; max-width: 1100px; }
  .nav-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 4px; color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; margin-bottom: 0.25rem; }
  .nav-item:hover, .nav-item.active { background: rgba(0,242,255,0.08); color: var(--accent); }
  .stat-card { background: rgba(10,12,18,0.6); border: 1px solid var(--border); padding: 1.5rem; border-radius: 4px; }
  .table-wrap { background: rgba(10,12,18,0.6); border: 1px solid var(--border); border-radius: 4px; overflow: hidden; }
  table { width: 100%; border-collapse: collapse; }
  th { background: rgba(0,242,255,0.05); padding: 1rem 1.5rem; text-align: left; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--accent); border-bottom: 1px solid var(--border); }
  td { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
  tr:last-child td { border-bottom: none; }
  .badge { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
  .btn-cyber { display: inline-block; padding: 0.65rem 1.5rem; border: 1px solid var(--accent); color: var(--accent); font-weight: 900; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; text-decoration: none; border-radius: 2px; transition: all 0.2s; }
  .btn-cyber:hover { background: rgba(0,242,255,0.1); }
  @media (max-width: 768px) { .layout { grid-template-columns: 1fr; } .sidebar { height: auto; position: static; } }
</style>

<div class="layout" id="dashboard">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div style="margin-bottom:2rem;">
      <img src="/brcprint.svg" alt="BRCPrint" style="height:36px;" />
    </div>
    <div id="user-info" style="margin-bottom:2rem;padding:1rem;background:rgba(0,242,255,0.05);border:1px solid var(--border);border-radius:4px;">
      <div style="font-size:0.7rem;color:var(--accent);font-weight:900;letter-spacing:2px;text-transform:uppercase;margin-bottom:0.5rem;">Cliente</div>
      <div id="user-name" style="font-weight:800;font-size:1rem;">Carregando...</div>
    </div>
    <nav>
      <a href="/minha-conta" class="nav-item active">📦 Meus Orçamentos</a>
      <a href="/minha-conta/nova-cotacao" class="nav-item">➕ Nova Cotação</a>
      <a href="/minha-conta/perfil" class="nav-item">👤 Meu Perfil</a>
      <a href="/minha-conta/afiliado" class="nav-item">🤝 Programa Afiliado</a>
    </nav>
    <div style="margin-top:auto;padding-top:2rem;border-top:1px solid var(--border);margin-top:2rem;">
      <button id="logout-btn" style="width:100%;padding:0.75rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#f87171;font-weight:700;font-size:0.8rem;cursor:pointer;border-radius:2px;text-transform:uppercase;letter-spacing:1px;">Sair</button>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2rem;">
      <div>
        <h1 style="font-size:1.8rem;font-weight:900;margin:0;text-transform:uppercase;">Meus <span style="color:var(--accent);">Orçamentos</span></h1>
        <p id="welcome-msg" style="color:var(--muted);font-size:0.9rem;margin:0.5rem 0 0;">Carregando...</p>
      </div>
      <a href="/minha-conta/nova-cotacao" class="btn-cyber">+ Nova Cotação</a>
    </div>

    <!-- Cashback / Saldo -->
    <div id="balances" style="display:none;gap:1.5rem;margin-bottom:2rem;grid-template-columns:1fr 1fr;display:grid;">
      <div class="stat-card" id="plan-card" style="display:none;border-top:3px solid #3b82f6;">
        <div style="font-size:0.75rem;color:#3b82f6;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.5rem;">💎 Assinatura B2B</div>
        <div id="plan-name" style="font-size:1.1rem;font-weight:900;color:#fff;"></div>
        <div id="plan-balance" style="font-size:0.85rem;color:var(--muted);margin-top:0.25rem;"></div>
      </div>
      <div class="stat-card" id="cashback-card" style="display:none;border-top:3px solid var(--neon-green);">
        <div style="font-size:0.75rem;color:var(--neon-green);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.5rem;">🪙 Saldo Cashback</div>
        <div id="cashback-val" style="font-size:1.8rem;font-weight:900;color:var(--neon-green);"></div>
      </div>
    </div>

    <!-- Tabela de cotações -->
    <div class="table-wrap">
      <div id="table-loading" style="padding:3rem;text-align:center;color:var(--muted);">Carregando seus pedidos...</div>
      <div id="table-empty" style="display:none;padding:4rem;text-align:center;color:var(--muted);">
        <p style="font-size:3rem;margin:0 0 1rem;">📦</p>
        <h3 style="margin:0 0 0.5rem;color:#fff;">Nenhum pedido ainda</h3>
        <p style="margin:0;">Você ainda não enviou nenhum arquivo para orçamento.</p>
        <a href="/minha-conta/nova-cotacao" style="display:inline-block;margin-top:1.5rem;color:var(--accent);font-weight:600;text-decoration:none;">Enviar meu primeiro arquivo 3D →</a>
      </div>
      <div id="table-content" style="display:none;">
        <table>
          <thead>
            <tr>
              <th>Arquivo / Projeto</th>
              <th>Material / Cor</th>
              <th>Qtd</th>
              <th>Status</th>
              <th>Valor</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody id="quotes-tbody"></tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script>
  const STATUS_MAP: Record<string, { label: string; color: string; icon: string }> = {
    pending: { label: 'Aguardando', color: '#f59e0b', icon: '⏳' },
    quoted: { label: 'Orçado', color: '#3b82f6', icon: '💰' },
    approved: { label: 'Aprovado', color: '#10b981', icon: '✅' },
    rejected: { label: 'Recusado', color: '#ef4444', icon: '❌' },
    printing: { label: 'Imprimindo', color: '#8b5cf6', icon: '🖨️' },
    shipped: { label: 'Enviado', color: '#06b6d4', icon: '📦' },
    delivered: { label: 'Entregue', color: '#22c55e', icon: '🏆' },
  };

  function getToken() {
    return localStorage.getItem('brc_token');
  }

  async function loadDashboard() {
    const token = getToken();
    if (!token) {
      window.location.href = '/minha-conta/login';
      return;
    }

    try {
      // Load client info
      const [clientRes, quotesRes] = await Promise.all([
        fetch('/api/v1/clients/me', { headers: { Authorization: `Bearer ${token}` } }),
        fetch('/api/v1/quotes/my', { headers: { Authorization: `Bearer ${token}` } }),
      ]);

      if (clientRes.status === 401) {
        localStorage.removeItem('brc_token');
        window.location.href = '/minha-conta/login';
        return;
      }

      const client = clientRes.ok ? await clientRes.json() : null;
      const quotes = quotesRes.ok ? await quotesRes.json() : [];

      if (client) {
        (document.getElementById('user-name') as HTMLElement).textContent = client.name || client.email;
        (document.getElementById('welcome-msg') as HTMLElement).textContent = `Olá, ${client.name?.split(' ')[0] || ''}! Que bom te ver por aqui.`;

        // Cashback
        if (Number(client.credit_balance) > 0) {
          const card = document.getElementById('cashback-card') as HTMLElement;
          card.style.display = 'block';
          (document.getElementById('cashback-val') as HTMLElement).textContent =
            Number(client.credit_balance).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        // B2B Plan
        if (client.subscription_status === 'active') {
          const card = document.getElementById('plan-card') as HTMLElement;
          card.style.display = 'block';
          (document.getElementById('plan-name') as HTMLElement).textContent = client.plan_name || 'Plano Ativo';
          (document.getElementById('plan-balance') as HTMLElement).textContent =
            `${Number(client.available_hours_balance || 0).toFixed(1)}h · ${Number(client.available_grams_balance || 0).toFixed(0)}g restantes`;
        }
      }

      // Render quotes
      (document.getElementById('table-loading') as HTMLElement).style.display = 'none';
      const arr = Array.isArray(quotes) ? quotes : [];
      if (arr.length === 0) {
        (document.getElementById('table-empty') as HTMLElement).style.display = 'block';
      } else {
        (document.getElementById('table-content') as HTMLElement).style.display = 'block';
        const tbody = document.getElementById('quotes-tbody') as HTMLTableSectionElement;
        tbody.innerHTML = arr.map((q: any) => {
          const s = STATUS_MAP[q.status] || { label: q.status, color: '#666', icon: '•' };
          const total = q.final_price
            ? Number(Number(q.final_price) + Number(q.tax_amount || 0) + Number(q.shipping_cost || 0))
                .toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })
            : '—';
          const name = q.title || (q.items?.[0]?.name) || 'Cotação';
          const portalLink = q.public_token
            ? `<a href="/portal/${q.public_token}" style="color:var(--accent);text-decoration:none;font-weight:700;font-size:0.8rem;border:1px solid var(--accent);padding:0.3rem 0.75rem;border-radius:2px;">VER</a>`
            : '—';
          return `<tr>
            <td>
              <div style="font-weight:700;">${name}</div>
              <div style="font-size:0.75rem;color:var(--muted);">Enviado em ${new Date(q.created_at).toLocaleDateString('pt-BR')}</div>
            </td>
            <td>
              <div style="font-weight:600;">${q.material_preference || 'Qualquer'}</div>
              <div style="font-size:0.75rem;color:var(--muted);">${q.color_preference || 'Não importa'}</div>
            </td>
            <td>${q.quantity || 1} un</td>
            <td><span class="badge" style="background:${s.color}22;color:${s.color};border:1px solid ${s.color}44;">${s.icon} ${s.label}</span></td>
            <td style="font-weight:800;color:${q.public_token ? 'var(--neon-green)' : 'var(--muted)'};">${total}</td>
            <td>${portalLink}</td>
          </tr>`;
        }).join('');
      }
    } catch (err) {
      console.error(err);
    }
  }

  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('brc_token');
    window.location.href = '/';
  });

  loadDashboard();
</script>
</Base>
