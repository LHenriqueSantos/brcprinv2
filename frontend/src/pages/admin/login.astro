---
import Base from '../../layouts/Base.astro';
---
<Base title="Admin Login — BRCPrint" showNav={false}>
<style>
  :root { --accent:#00f2ff; --border:rgba(255,255,255,0.08); --muted:rgba(255,255,255,0.45); }
  body { background:#05060a; color:#fff; font-family:'Inter',sans-serif; }
  .wrap { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem; }
  .card { width:100%; max-width:380px; background:rgba(10,12,18,0.95); border:1px solid var(--border); border-top:3px solid var(--accent); padding:2.5rem 2rem; }
  .input-field { width:100%; background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:4px; padding:0.85rem 1rem; color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif; box-sizing:border-box; transition:border-color 0.2s; }
  .input-field:focus { outline:none; border-color:var(--accent); }
  .label { display:block; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--accent); margin-bottom:0.5rem; }
  .btn { width:100%; padding:1rem; background:transparent; border:1px solid var(--accent); color:var(--accent); font-weight:900; font-size:0.9rem; text-transform:uppercase; letter-spacing:3px; cursor:pointer; font-family:'Inter',sans-serif; border-radius:2px; transition:all 0.2s; }
  .btn:hover { background:rgba(0,242,255,0.1); }
</style>
<div class="wrap">
  <div class="card">
    <div style="text-align:center;margin-bottom:2rem;">
      <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:var(--accent);margin-bottom:0.5rem;">BRCPRINT</div>
      <h1 style="font-size:1.1rem;font-weight:900;text-transform:uppercase;letter-spacing:2px;margin:0;">Painel Administrativo</h1>
    </div>
    <div id="error-msg" style="display:none;padding:0.75rem;background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.3);border-radius:4px;color:#f87171;margin-bottom:1rem;font-size:0.85rem;"></div>
    <form id="login-form">
      <div style="margin-bottom:1rem;">
        <label class="label">E-mail</label>
        <input class="input-field" type="email" id="email" autofocus required />
      </div>
      <div style="margin-bottom:1.5rem;">
        <label class="label">Senha</label>
        <input class="input-field" type="password" id="password" required />
      </div>
      <button type="submit" class="btn" id="btn">ENTRAR</button>
    </form>
  </div>
</div>
<script>
  // Redirect if already logged in
  if (localStorage.getItem('brc_admin_token')) window.location.href = '/admin';

  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn') as HTMLButtonElement;
    const errEl = document.getElementById('error-msg') as HTMLElement;
    btn.textContent = 'AUTENTICANDO...'; btn.disabled = true; errEl.style.display = 'none';
    const fd = new FormData();
    fd.append('username', (document.getElementById('email') as HTMLInputElement).value);
    fd.append('password', (document.getElementById('password') as HTMLInputElement).value);
    try {
      const res = await fetch('/api/v1/auth/admin/token', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Credenciais inválidas');
      localStorage.setItem('brc_admin_token', data.access_token);
      window.location.href = '/admin';
    } catch (err: any) {
      errEl.textContent = err.message; errEl.style.display = 'block';
      btn.textContent = 'ENTRAR'; btn.disabled = false;
    }
  });
</script>
</Base>
