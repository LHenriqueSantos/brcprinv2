---
import Base from '../../../layouts/Base.astro';
---
<Base title="Catálogo — Admin BRCPrint" showNav={false}>
<style>
  :root { --accent:#00f2ff; --border:rgba(255,255,255,0.08); --muted:rgba(255,255,255,0.45); }
  body { background:#05060a; color:#fff; font-family:'Inter',sans-serif; }
  .layout { display:grid; grid-template-columns:220px 1fr; min-height:100vh; }
  .sidebar { background:#070810; border-right:1px solid var(--border); padding:1.5rem 1rem; }
  .main { padding:2rem 2.5rem; }
  .nav-item { display:flex; align-items:center; gap:0.75rem; padding:0.65rem 0.875rem; color:var(--muted); text-decoration:none; font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; border-radius:3px; transition:all 0.2s; margin-bottom:0.2rem; }
  .nav-item:hover,.nav-item.active { background:rgba(0,242,255,0.06); color:var(--accent); }
  .input-field { background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:4px; padding:0.65rem 0.875rem; color:#fff; font-family:'Inter',sans-serif; font-size:0.85rem; width:100%; box-sizing:border-box; }
  .input-field:focus { outline:none; border-color:var(--accent); }
  label.lbl { display:block; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--accent); margin-bottom:0.4rem; }
  .grid-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.25rem; }
  .item-card { background:#070810; border:1px solid var(--border); border-radius:4px; overflow:hidden; transition:border-color 0.2s; }
  .item-card:hover { border-color:rgba(0,242,255,0.3); }
  .btn { padding:0.65rem 1.25rem; background:transparent; border:1px solid; border-radius:2px; font-size:0.75rem; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; text-transform:uppercase; letter-spacing:1px; transition:all 0.15s; }
  .modal-bg { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:999; align-items:center; justify-content:center; }
</style>

<div class="layout">
  <aside class="sidebar">
    <div style="margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);">
      <img src="/brcprint.svg" alt="BRCPrint" style="height:30px;" onerror="this.style.display='none'" />
      <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--accent);margin-top:0.5rem;">PAINEL ADMIN</div>
    </div>
    <nav>
      <a href="/admin" class="nav-item">📊 Dashboard</a>
      <a href="/admin/cotacoes" class="nav-item">💰 Cotações</a>
      <a href="/admin/pedidos" class="nav-item">📦 Pedidos</a>
      <a href="/admin/clientes" class="nav-item">👤 Clientes</a>
      <a href="/admin/catalogo" class="nav-item active">🧊 Catálogo</a>
      <a href="/admin/impressoras" class="nav-item">🖨️ Impressoras</a>
      <a href="/admin/filamentos" class="nav-item">🧵 Filamentos</a>
      <a href="/admin/leiloes" class="nav-item">⚡ Leilões</a>
    </nav>
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);">
      <button id="btn-logout" style="width:100%;padding:0.6rem;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.3);color:#f87171;font-size:0.75rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;border-radius:2px;text-transform:uppercase;">Sair</button>
    </div>
  </aside>

  <main class="main">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
      <h1 style="font-size:1.4rem;font-weight:900;margin:0;text-transform:uppercase;">Catálogo <span style="color:var(--accent);">3D</span></h1>
      <button class="btn" id="btn-add" style="color:var(--accent);border-color:rgba(0,242,255,0.4);">+ NOVO ITEM</button>
    </div>

    <div id="success-msg" style="display:none;padding:0.875rem 1.25rem;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-radius:4px;color:#22c55e;margin-bottom:1.5rem;font-weight:700;"></div>
    <div id="error-msg" style="display:none;padding:0.875rem 1.25rem;background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.3);border-radius:4px;color:#f87171;margin-bottom:1.5rem;"></div>

    <div class="grid-cards" id="catalog-grid">
      <div style="text-align:center;padding:4rem 2rem;color:var(--muted);" id="loading-msg">Carregando catálogo...</div>
    </div>
  </main>
</div>

<!-- Modal -->
<div class="modal-bg" id="item-modal">
  <div style="background:#070810;border:1px solid var(--border);border-radius:4px;padding:2rem;width:560px;max-width:94vw;max-height:88vh;overflow-y:auto;">
    <h3 id="modal-title" style="font-size:0.9rem;font-weight:900;text-transform:uppercase;letter-spacing:2px;color:var(--accent);margin:0 0 1.5rem;">Novo Item</h3>
    <input type="hidden" id="edit-id" />
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div><label class="lbl">Nome *</label><input class="input-field" id="f-name" /></div>
      <div><label class="lbl">Categoria</label><input class="input-field" id="f-category" /></div>
    </div>
    <div style="margin-bottom:1rem;"><label class="lbl">Descrição</label><textarea class="input-field" id="f-desc" rows="2"></textarea></div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div><label class="lbl">Material</label><input class="input-field" id="f-material" placeholder="PLA" /></div>
      <div><label class="lbl">Cor</label><input class="input-field" id="f-color" /></div>
      <div><label class="lbl">Preço Base (R$)</label><input class="input-field" type="number" id="f-price" step="0.01" /></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div><label class="lbl">URL Imagem</label><input class="input-field" id="f-image" placeholder="https://..." /></div>
      <div><label class="lbl">URL Arquivo STL/3MF</label><input class="input-field" id="f-file" placeholder="https://..." /></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
      <div><label class="lbl">Peso estimado (g)</label><input class="input-field" type="number" id="f-weight" /></div>
      <div><label class="lbl">Tempo estimado (h)</label><input class="input-field" type="number" id="f-time" step="0.1" /></div>
    </div>
    <div style="display:flex;gap:1rem;margin-bottom:1.5rem;">
      <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;"><input type="checkbox" id="f-active" checked /> Ativo</label>
      <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;cursor:pointer;"><input type="checkbox" id="f-featured" /> Destaque</label>
    </div>
    <div style="display:flex;gap:0.75rem;">
      <button class="btn" id="modal-cancel" style="color:var(--muted);border-color:var(--border);">CANCELAR</button>
      <button class="btn" id="modal-save" style="color:var(--accent);border-color:rgba(0,242,255,0.4);">SALVAR</button>
      <button class="btn" id="modal-delete" style="display:none;color:#f87171;border-color:rgba(239,68,68,0.3);">EXCLUIR</button>
    </div>
  </div>
</div>

<script>
  function headers() {
    const t = localStorage.getItem('brc_admin_token') || '';
    return { Authorization: `Bearer ${t}`, 'Content-Type': 'application/json' };
  }

  async function loadCatalog() {
    if (!localStorage.getItem('brc_admin_token')) { window.location.href = '/admin/login'; return; }
    const grid = document.getElementById('catalog-grid') as HTMLElement;
    try {
      const res = await fetch('/api/v1/catalog', { headers: { Authorization: `Bearer ${localStorage.getItem('brc_admin_token')}` } });
      const items = await res.json();
      if (!Array.isArray(items) || items.length === 0) {
        grid.innerHTML = '<div style="text-align:center;padding:4rem 2rem;color:var(--muted);">Nenhum item no catálogo. Clique em "+ NOVO ITEM" para adicionar.</div>';
        return;
      }
      grid.innerHTML = items.map((item: any) => `
        <div class="item-card">
          ${item.image_url ? `<img src="${item.image_url}" style="width:100%;height:160px;object-fit:cover;" alt="${item.name}" />` : '<div style="width:100%;height:160px;background:#0d0f14;display:flex;align-items:center;justify-content:center;font-size:3rem;">🧊</div>'}
          <div style="padding:1rem;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.4rem;">
              <div style="font-weight:800;font-size:0.9rem;">${item.name}</div>
              ${item.featured ? '<span style="font-size:0.65rem;background:rgba(0,242,255,0.1);color:var(--accent);padding:0.15rem 0.5rem;border-radius:999px;border:1px solid rgba(0,242,255,0.3);">⭐ DESTAQUE</span>' : ''}
            </div>
            ${item.category ? `<div style="font-size:0.75rem;color:var(--muted);margin-bottom:0.5rem;">${item.category}</div>` : ''}
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.75rem;">
              <div style="font-weight:900;color:var(--accent);">${item.base_price ? `R$ ${Number(item.base_price).toFixed(2).replace('.',',')}` : 'Sob consulta'}</div>
              <button class="btn edit-btn" data-id="${item.id}" style="font-size:0.7rem;color:var(--muted);border-color:var(--border);padding:0.3rem 0.75rem;">EDITAR</button>
            </div>
          </div>
        </div>
      `).join('');

      document.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = Number((btn as HTMLElement).dataset.id);
          const item = items.find((i: any) => i.id === id);
          if (!item) return;
          openModal(item);
        });
      });
    } catch { grid.innerHTML = '<div style="text-align:center;padding:3rem;color:#f87171;">Erro ao carregar catálogo.</div>'; }
  }

  function openModal(item?: any) {
    (document.getElementById('edit-id') as HTMLInputElement).value = item?.id || '';
    (document.getElementById('modal-title') as HTMLElement).textContent = item ? `Editar: ${item.name}` : 'Novo Item';
    (document.getElementById('f-name') as HTMLInputElement).value = item?.name || '';
    (document.getElementById('f-category') as HTMLInputElement).value = item?.category || '';
    (document.getElementById('f-desc') as HTMLTextAreaElement).value = item?.description || '';
    (document.getElementById('f-material') as HTMLInputElement).value = item?.material || '';
    (document.getElementById('f-color') as HTMLInputElement).value = item?.color || '';
    (document.getElementById('f-price') as HTMLInputElement).value = item?.base_price || '';
    (document.getElementById('f-image') as HTMLInputElement).value = item?.image_url || '';
    (document.getElementById('f-file') as HTMLInputElement).value = item?.file_url || '';
    (document.getElementById('f-weight') as HTMLInputElement).value = item?.weight_g || '';
    (document.getElementById('f-time') as HTMLInputElement).value = item?.print_time_h || '';
    (document.getElementById('f-active') as HTMLInputElement).checked = item?.active !== false;
    (document.getElementById('f-featured') as HTMLInputElement).checked = !!item?.featured;
    (document.getElementById('modal-delete') as HTMLButtonElement).style.display = item ? 'block' : 'none';
    (document.getElementById('item-modal') as HTMLElement).style.display = 'flex';
  }

  document.getElementById('btn-add')?.addEventListener('click', () => openModal());
  document.getElementById('modal-cancel')?.addEventListener('click', () => { (document.getElementById('item-modal') as HTMLElement).style.display = 'none'; });

  document.getElementById('modal-save')?.addEventListener('click', async () => {
    const id = (document.getElementById('edit-id') as HTMLInputElement).value;
    const body = {
      name: (document.getElementById('f-name') as HTMLInputElement).value,
      category: (document.getElementById('f-category') as HTMLInputElement).value || null,
      description: (document.getElementById('f-desc') as HTMLTextAreaElement).value || null,
      material: (document.getElementById('f-material') as HTMLInputElement).value || null,
      color: (document.getElementById('f-color') as HTMLInputElement).value || null,
      base_price: parseFloat((document.getElementById('f-price') as HTMLInputElement).value) || null,
      image_url: (document.getElementById('f-image') as HTMLInputElement).value || null,
      file_url: (document.getElementById('f-file') as HTMLInputElement).value || null,
      weight_g: parseFloat((document.getElementById('f-weight') as HTMLInputElement).value) || null,
      print_time_h: parseFloat((document.getElementById('f-time') as HTMLInputElement).value) || null,
      active: (document.getElementById('f-active') as HTMLInputElement).checked,
      featured: (document.getElementById('f-featured') as HTMLInputElement).checked,
    };
    const url = id ? `/api/v1/catalog/${id}` : '/api/v1/catalog';
    const method = id ? 'PATCH' : 'POST';
    const res = await fetch(url, { method, headers: headers(), body: JSON.stringify(body) });
    if (res.ok) {
      (document.getElementById('item-modal') as HTMLElement).style.display = 'none';
      showMsg('Item salvo com sucesso!', 'success');
      loadCatalog();
    } else {
      const e = await res.json(); showMsg(e.detail || 'Erro ao salvar.', 'error');
    }
  });

  document.getElementById('modal-delete')?.addEventListener('click', async () => {
    const id = (document.getElementById('edit-id') as HTMLInputElement).value;
    if (!id || !confirm('Excluir este item?')) return;
    const res = await fetch(`/api/v1/catalog/${id}`, { method: 'DELETE', headers: headers() });
    if (res.ok) { (document.getElementById('item-modal') as HTMLElement).style.display = 'none'; showMsg('Item excluído.', 'success'); loadCatalog(); }
    else showMsg('Erro ao excluir.', 'error');
  });

  function showMsg(msg: string, type: 'success' | 'error') {
    const el = document.getElementById(type === 'success' ? 'success-msg' : 'error-msg') as HTMLElement;
    el.textContent = (type === 'success' ? '✅ ' : '❌ ') + msg;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 4000);
  }

  document.getElementById('btn-logout')?.addEventListener('click', () => { localStorage.removeItem('brc_admin_token'); window.location.href = '/admin/login'; });
  loadCatalog();
</script>
</Base>
