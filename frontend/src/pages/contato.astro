---
import Base from '../layouts/Base.astro';
---
<Base title="Contato — BRCPrint">
<style>
  :root { --accent:#00f2ff; --border:rgba(255,255,255,0.08); --muted:rgba(255,255,255,0.45); }
  body { background:#05060a; color:#fff; font-family:'Inter',sans-serif; }
  .wrap { max-width:700px; margin:0 auto; padding:5rem 1.5rem; }
  .input-field { width:100%; background:rgba(255,255,255,0.04); border:1px solid var(--border); border-radius:4px; padding:0.85rem 1rem; color:#fff; font-size:0.95rem; font-family:'Inter',sans-serif; transition:border-color 0.2s; box-sizing:border-box; }
  .input-field:focus { outline:none; border-color:var(--accent); }
  .label { display:block; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:var(--accent); margin-bottom:0.5rem; }
  .field { margin-bottom:1.25rem; }
  .btn { width:100%; padding:1rem; background:transparent; border:1px solid var(--accent); color:var(--accent); font-weight:900; font-size:0.9rem; text-transform:uppercase; letter-spacing:3px; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.2s; border-radius:2px; }
  .btn:hover { background:rgba(0,242,255,0.1); box-shadow:0 0 20px rgba(0,242,255,0.2); }
</style>
<div class="wrap">
  <div style="text-align:center;margin-bottom:3rem;">
    <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;color:var(--accent);margin-bottom:0.75rem;">// CONTATO</div>
    <h1 style="font-size:2.5rem;font-weight:900;margin:0 0 1rem;">Fale <span style="color:var(--accent);">Conosco</span></h1>
    <p style="color:var(--muted);">Tem dúvidas, projetos especiais ou quer um orçamento personalizado? Manda mensagem!</p>
  </div>

  <div id="success-msg" style="display:none;padding:1.5rem;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);border-radius:4px;color:#22c55e;text-align:center;margin-bottom:2rem;font-weight:700;">
    ✅ Mensagem enviada! Retornaremos em breve via WhatsApp ou e-mail.
  </div>
  <div id="error-msg" style="display:none;padding:1rem;background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.3);border-radius:4px;color:#f87171;margin-bottom:1.5rem;"></div>

  <form id="contact-form">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
      <div class="field">
        <label class="label" for="name">Nome</label>
        <input class="input-field" type="text" id="name" placeholder="Seu nome" required />
      </div>
      <div class="field">
        <label class="label" for="email">E-mail</label>
        <input class="input-field" type="email" id="email" placeholder="seu@email.com" required />
      </div>
    </div>
    <div class="field">
      <label class="label" for="phone">WhatsApp (opcional)</label>
      <input class="input-field" type="tel" id="phone" placeholder="(11) 99999-9999" />
    </div>
    <div class="field">
      <label class="label" for="subject">Assunto</label>
      <select class="input-field" id="subject">
        <option>Orçamento de impressão</option>
        <option>Orçamento manual (sem arquivo)</option>
        <option>Suporte a pedido existente</option>
        <option>Parceria / B2B</option>
        <option>Outro</option>
      </select>
    </div>
    <div class="field">
      <label class="label" for="message">Mensagem</label>
      <textarea class="input-field" id="message" rows="5" placeholder="Descreva seu projeto ou dúvida..." required></textarea>
    </div>
    <button type="submit" class="btn" id="send-btn">ENVIAR MENSAGEM</button>
  </form>

  <!-- Canais diretos -->
  <div style="margin-top:3rem;display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
    <a href="https://wa.me/5511999999999" target="_blank" style="text-decoration:none;display:flex;align-items:center;gap:1rem;padding:1.25rem;background:rgba(10,12,18,0.7);border:1px solid var(--border);border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='#25d366'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:1.5rem;">💬</span>
      <div><div style="font-weight:800;font-size:0.9rem;">WhatsApp</div><div style="font-size:0.8rem;color:var(--muted);">Resposta rápida</div></div>
    </a>
    <a href="mailto:contato@brcprint.com.br" style="text-decoration:none;display:flex;align-items:center;gap:1rem;padding:1.25rem;background:rgba(10,12,18,0.7);border:1px solid var(--border);border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:1.5rem;">📧</span>
      <div><div style="font-weight:800;font-size:0.9rem;">E-mail</div><div style="font-size:0.8rem;color:var(--muted);">contato@brcprint.com.br</div></div>
    </a>
  </div>
</div>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('send-btn') as HTMLButtonElement;
    const errEl = document.getElementById('error-msg') as HTMLElement;
    btn.textContent = 'ENVIANDO...'; btn.disabled = true; errEl.style.display = 'none';
    try {
      const res = await fetch('/api/v1/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (document.getElementById('name') as HTMLInputElement).value,
          email: (document.getElementById('email') as HTMLInputElement).value,
          phone: (document.getElementById('phone') as HTMLInputElement).value,
          subject: (document.getElementById('subject') as HTMLSelectElement).value,
          message: (document.getElementById('message') as HTMLTextAreaElement).value,
        })
      });
      if (!res.ok) { const d = await res.json(); throw new Error(d.detail || 'Erro ao enviar.'); }
      (document.getElementById('contact-form') as HTMLFormElement).style.display = 'none';
      (document.getElementById('success-msg') as HTMLElement).style.display = 'block';
    } catch (err: any) {
      errEl.textContent = err.message; errEl.style.display = 'block';
      btn.textContent = 'ENVIAR MENSAGEM'; btn.disabled = false;
    }
  });
</script>
</Base>
