---
import Base from '../../layouts/Base.astro';
---
<Base title="Pedido Confirmado — BRCPrint">
<style>
  :root { --accent:#00f2ff; --neon-green:#00ff94; --border:rgba(255,255,255,0.08); --muted:rgba(255,255,255,0.45); }
  body { background:#05060a; color:#fff; font-family:'Inter',sans-serif; }
</style>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem;text-align:center;background:radial-gradient(ellipse at 50% 30%,rgba(0,255,148,0.07) 0%,transparent 60%);">
  <div style="max-width:520px;">
    <div style="font-size:5rem;margin-bottom:1.5rem;animation:pop 0.5s cubic-bezier(0.175,0.885,0.32,1.275);">✅</div>
    <h1 style="font-size:2.5rem;font-weight:900;margin:0 0 1rem;text-transform:uppercase;">Pedido <span style="color:var(--neon-green);">Confirmado!</span></h1>
    <p style="color:var(--muted);font-size:1rem;line-height:1.6;margin:0 0 2rem;">
      Seu pedido foi recebido com sucesso! Entraremos em contato via WhatsApp para confirmar os detalhes e acompanhar o progresso da sua impressão 3D.
    </p>
    <div style="background:rgba(10,12,18,0.8);border:1px solid rgba(0,255,148,0.2);border-radius:4px;padding:1.5rem;margin-bottom:2rem;">
      <div style="font-size:0.75rem;color:var(--neon-green);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:0.75rem;">🏆 Próximos Passos</div>
      <div style="display:flex;flex-direction:column;gap:0.75rem;text-align:left;">
        <div style="display:flex;gap:0.75rem;align-items:center;font-size:0.9rem;"><span>1️⃣</span><span>Confirmação por e-mail e WhatsApp</span></div>
        <div style="display:flex;gap:0.75rem;align-items:center;font-size:0.9rem;"><span>2️⃣</span><span>Início da produção em até 24h</span></div>
        <div style="display:flex;gap:0.75rem;align-items:center;font-size:0.9rem;"><span>3️⃣</span><span>Rastreamento e entrega</span></div>
      </div>
    </div>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/minha-conta" style="display:inline-block;padding:0.85rem 2rem;border:1px solid var(--accent);color:var(--accent);font-weight:900;font-size:0.85rem;text-transform:uppercase;letter-spacing:2px;text-decoration:none;border-radius:2px;transition:all 0.2s;" onmouseover="this.style.background='rgba(0,242,255,0.1)'" onmouseout="this.style.background='transparent'">Meus Pedidos</a>
      <a href="/" style="display:inline-block;padding:0.85rem 2rem;border:1px solid var(--border);color:var(--muted);font-weight:700;font-size:0.85rem;text-decoration:none;border-radius:2px;">Início</a>
    </div>
  </div>
</div>
<style>
  @keyframes pop { from { transform:scale(0); } to { transform:scale(1); } }
</style>
<script is:inline>
  // Clear cart on success
  localStorage.removeItem('brc_cart');
</script>
</Base>
